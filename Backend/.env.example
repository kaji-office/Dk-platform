# ─────────────────────────────────────────────────────────────────────────────
# AI Workflow Builder — Environment Variables Reference
# Copy to .env and fill in values before running locally.
# Production values are stored in AWS Secrets Manager — never in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
AWS_REGION=us-east-1

# ── Database — MongoDB ────────────────────────────────────────────────────────
# Local (docker-compose):
MONGODB_URL=mongodb://localhost:27017/workflow_platform
# Atlas (staging/prod): mongodb+srv://user:pass@cluster.mongodb.net/workflow_platform

# ── Database — PostgreSQL ─────────────────────────────────────────────────────
# Local (docker-compose):
POSTGRES_URL=postgresql://workflow:devpassword@localhost:5432/workflow_platform
# asyncpg format for SDK: postgresql+asyncpg://workflow:devpassword@localhost:5432/workflow_platform
POSTGRES_URL_ASYNCPG=postgresql+asyncpg://workflow:devpassword@localhost:5432/workflow_platform

# ── Cache / Queue — Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:devpassword@localhost:6379/0
CELERY_BROKER_URL=redis://:devpassword@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:devpassword@localhost:6379/1

# ── Storage — S3 ─────────────────────────────────────────────────────────────
# Local (LocalStack):
S3_BUCKET=workflow-platform-dev
AWS_ENDPOINT_URL=http://localhost:4566    # LocalStack only — remove in staging/prod
AWS_ACCESS_KEY_ID=test                    # LocalStack only
AWS_SECRET_ACCESS_KEY=test               # LocalStack only

# Staging/prod (uses IRSA — no static credentials needed):
# S3_BUCKET=workflow-platform-us-east-1

# ── Auth — JWT ────────────────────────────────────────────────────────────────
# Generate RSA key pair:
#   mkdir -p keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# File-path style (local dev):
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Raw-string style (K8s/prod — inline PEM with \n escaped):
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Generate HMAC secret: openssl rand -hex 32
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# ── Auth — OAuth Providers ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# ── LLM Providers ────────────────────────────────────────────────────────────
# LLM_PROVIDER selects the backend for AINode execution.
# Valid values: openai | google | anthropic | bedrock | vertex | mock
# Use "mock" for local development without real API keys.
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
VERTEX_AI_PROJECT=your-gcp-project
VERTEX_AI_LOCATION=us-central1
# Amazon Bedrock uses IRSA in production — no key needed
# For local testing with real Bedrock:
# AWS_BEDROCK_REGION=us-east-1

# ── Notifications ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM_ADDRESS=noreply@workflowplatform.com
EMAIL_FROM_NAME=Workflow Platform

# ── Integrations — Connectors ─────────────────────────────────────────────────
# Connector OAuth credentials are stored per-tenant in PostgreSQL (encrypted)
# These are platform-level app registrations:
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
MICROSOFT_TEAMS_CLIENT_ID=
MICROSOFT_TEAMS_CLIENT_SECRET=
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                      # Uvicorn workers (1 for dev, auto for prod)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Worker ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_QUEUES=default,ai-heavy,critical,scheduled

# ── Sandbox ───────────────────────────────────────────────────────────────────
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_TIER2_ENABLED=true
SANDBOX_WARM_POOL_SIZE=5           # Pre-warmed gVisor containers per worker pod

# ── Billing ───────────────────────────────────────────────────────────────────
PLATFORM_MARGIN_PERCENT=20.0

# ── Observability ─────────────────────────────────────────────────────────────
# Local: structured JSON to stdout
# Staging/prod: CloudWatch (via CloudWatch agent — no additional config needed)
OTEL_EXPORTER=none                 # none | cloudwatch | stdout
XRAY_ENABLED=false                 # true in staging/prod

# ── Feature Flags ─────────────────────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
MCP_NODE_ENABLED=false             # v1.1
HUMAN_NODE_ENABLED=false           # v1.1
DEDICATED_INFRA_ENABLED=false      # v1.2
FIRECRACKER_ENABLED=false          # v2.0
