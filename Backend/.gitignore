# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep Dockerfiles committed; ignore local build artifacts
.docker/
docker-compose.override.yml

# ── Kubernetes / Helm ─────────────────────────────────────────────────────────
# Keep manifests committed; ignore generated lock files and rendered outputs
infra/helm/*/charts/*.tgz
infra/helm/*/Chart.lock
rendered/
*.rendered.yaml

# ── Databases (local dev) ─────────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
pgdata/
mongodata/
redisdata/

# ── Temporary / Scratch Files ─────────────────────────────────────────────────
tmp/
temp/
scratch/
*.tmp
*.bak
*.swp
*.orig
fix_openapi.py
update_tasks.py
update_tasks_fix.py

# ── OS Generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Pre-commit ────────────────────────────────────────────────────────────────
